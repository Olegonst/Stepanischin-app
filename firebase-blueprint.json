{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "nickname": { "type": "string" },
        "bio": { "type": "string" },
        "status": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "isIncognito": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "phoneNumber", "nickname"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between users, a group, or a channel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["private", "group", "channel"] },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "photoURL": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "admins": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "members"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "fileURL": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "file", "video_call"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "senderId", "type", "createdAt"]
    },
    "Story": {
      "title": "Story",
      "description": "A temporary status update (24h)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "mediaURL": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "caption": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "mediaURL", "createdAt", "expiresAt"]
    },
    "Reel": {
      "title": "Reel",
      "description": "Short video content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "videoURL": { "type": "string" },
        "caption": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "videoURL", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/chats/{chatId}": { "schema": "Chat", "description": "Chat metadata" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages in a chat" },
    "/stories/{storyId}": { "schema": "Story", "description": "User stories" },
    "/reels/{reelId}": { "schema": "Reel", "description": "Short videos" }
  }
}
